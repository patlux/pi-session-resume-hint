{
  "name": "pi-session-resume-hint",
  "version": "0.1.1",
  "description": "Print a compact Pi session resume command when an interactive Pi session exits.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patlux/pi-session-resume-hint.git"
  },
  "homepage": "https://github.com/patlux/pi-session-resume-hint#readme",
  "bugs": {
    "url": "https://github.com/patlux/pi-session-resume-hint/issues"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
